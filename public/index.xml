    <item>
      <title>Amortization Calculator</title>
      <link>http://localhost:1313/amortization-calculator/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/amortization-calculator/</guid>
      <description>&lt;div class=&#34;calc-card&#34;&gt;&#xA;  &lt;div class=&#34;calc-grid&#34;&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;am-loan&#34;&gt;Loan Amount&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;am-loan&#34; value=&#34;320000&#34; min=&#34;1000&#34; step=&#34;1000&#34;&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;am-rate&#34;&gt;Annual Interest Rate&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-suffix&#34;&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;am-rate&#34; value=&#34;7.00&#34; min=&#34;0.1&#34; max=&#34;30&#34; step=&#34;0.05&#34;&gt;&#xA;        &lt;span class=&#34;suffix&#34;&gt;%&lt;/span&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;am-term&#34;&gt;Loan Term&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap&#34;&gt;&#xA;        &lt;select id=&#34;am-term&#34;&gt;&#xA;          &lt;option value=&#34;30&#34;&gt;30 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;20&#34;&gt;20 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;15&#34;&gt;15 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;10&#34;&gt;10 Years&lt;/option&gt;&#xA;        &lt;/select&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;am-start&#34;&gt;Start Date&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap&#34;&gt;&#xA;        &lt;input type=&#34;month&#34; id=&#34;am-start&#34;&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;btn-row&#34;&gt;&#xA;      &lt;button class=&#34;btn btn-primary&#34; onclick=&#34;calcAmort()&#34;&gt;Generate Schedule&lt;/button&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&#xA;  &lt;div class=&#34;results&#34; id=&#34;am-results&#34;&gt;&#xA;    &lt;div class=&#34;result-grid&#34;&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;am-payment&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Monthly Payment&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;am-total-int&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Total Interest&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;am-total-cost&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Total Cost&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;amort-controls&#34;&gt;&#xA;      &lt;span style=&#34;font-size:.9rem;font-weight:600&#34;&gt;View:&lt;/span&gt;&#xA;      &lt;button class=&#34;toggle-btn active&#34; id=&#34;am-btn-year&#34; onclick=&#34;setView(&#39;year&#39;)&#34;&gt;Yearly&lt;/button&gt;&#xA;      &lt;button class=&#34;toggle-btn&#34; id=&#34;am-btn-month&#34; onclick=&#34;setView(&#39;month&#39;)&#34;&gt;Monthly&lt;/button&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;table-wrap&#34;&gt;&#xA;      &lt;table id=&#34;am-table&#34;&gt;&#xA;        &lt;thead&gt;&#xA;          &lt;tr&gt;&#xA;            &lt;th&gt;Period&lt;/th&gt;&#xA;            &lt;th&gt;Payment&lt;/th&gt;&#xA;            &lt;th&gt;Principal&lt;/th&gt;&#xA;            &lt;th&gt;Interest&lt;/th&gt;&#xA;            &lt;th&gt;Balance&lt;/th&gt;&#xA;          &lt;/tr&gt;&#xA;        &lt;/thead&gt;&#xA;        &lt;tbody id=&#34;am-tbody&#34;&gt;&lt;/tbody&gt;&#xA;      &lt;/table&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script&gt;&#xA;(function(){&#xA;  &#xA;  const startEl = document.getElementById(&#39;am-start&#39;);&#xA;  const d = new Date();&#xA;  d.setMonth(d.getMonth() + 1);&#xA;  startEl.value = d.toISOString().slice(0, 7);&#xA;&#xA;  let _schedule = [];&#xA;  let _view = &#39;year&#39;;&#xA;&#xA;  window.setView = function(v) {&#xA;    _view = v;&#xA;    document.getElementById(&#39;am-btn-year&#39;).classList.toggle(&#39;active&#39;, v === &#39;year&#39;);&#xA;    document.getElementById(&#39;am-btn-month&#39;).classList.toggle(&#39;active&#39;, v === &#39;month&#39;);&#xA;    renderTable();&#xA;  };&#xA;&#xA;  window.calcAmort = function() {&#xA;    const loan = parseFloat(document.getElementById(&#39;am-loan&#39;).value) || 0;&#xA;    const rate = parseFloat(document.getElementById(&#39;am-rate&#39;).value) || 0;&#xA;    const term = parseInt(document.getElementById(&#39;am-term&#39;).value) || 30;&#xA;    const startStr = document.getElementById(&#39;am-start&#39;).value;&#xA;    if (loan &lt;= 0 || rate &lt;= 0) return;&#xA;&#xA;    const mr = rate / 100 / 12;&#xA;    const n = term * 12;&#xA;    const payment = loan * (mr * Math.pow(1 + mr, n)) / (Math.pow(1 + mr, n) - 1);&#xA;&#xA;    let balance = loan;&#xA;    _schedule = [];&#xA;    let [startYear, startMonth] = startStr ? startStr.split(&#39;-&#39;).map(Number) : [new Date().getFullYear(), new Date().getMonth() + 2];&#xA;&#xA;    let totalInterest = 0;&#xA;&#xA;    for (let i = 1; i &lt;= n; i++) {&#xA;      const interest = balance * mr;&#xA;      const principal = payment - interest;&#xA;      balance = Math.max(balance - principal, 0);&#xA;      totalInterest += interest;&#xA;      const mIdx = (startMonth - 1 + i - 1) % 12;&#xA;      const yr = startYear + Math.floor((startMonth - 1 + i - 1) / 12);&#xA;      _schedule.push({ month: i, year: yr, mName: new Date(yr, mIdx).toLocaleString(&#39;en-US&#39;,{month:&#39;short&#39;}), interest, principal, balance, payment });&#xA;    }&#xA;&#xA;    const fmt = v =&gt; &#39;$&#39; + v.toLocaleString(&#39;en-US&#39;, {minimumFractionDigits: 0, maximumFractionDigits: 0});&#xA;    document.getElementById(&#39;am-payment&#39;).textContent   = fmt(payment);&#xA;    document.getElementById(&#39;am-total-int&#39;).textContent = fmt(totalInterest);&#xA;    document.getElementById(&#39;am-total-cost&#39;).textContent = fmt(payment * n);&#xA;    document.getElementById(&#39;am-results&#39;).classList.add(&#39;visible&#39;);&#xA;    renderTable();&#xA;  };&#xA;&#xA;  function renderTable() {&#xA;    const tbody = document.getElementById(&#39;am-tbody&#39;);&#xA;    tbody.innerHTML = &#39;&#39;;&#xA;    const fmt = v =&gt; &#39;$&#39; + v.toLocaleString(&#39;en-US&#39;, {minimumFractionDigits: 0, maximumFractionDigits: 0});&#xA;&#xA;    if (_view === &#39;year&#39;) {&#xA;      &#xA;      const years = {};&#xA;      _schedule.forEach(r =&gt; {&#xA;        if (!years[r.year]) years[r.year] = { interest: 0, principal: 0, payment: 0, balance: 0 };&#xA;        years[r.year].interest  += r.interest;&#xA;        years[r.year].principal += r.principal;&#xA;        years[r.year].payment   += r.payment;&#xA;        years[r.year].balance    = r.balance;&#xA;      });&#xA;      Object.entries(years).forEach(([yr, d]) =&gt; {&#xA;        const tr = document.createElement(&#39;tr&#39;);&#xA;        tr.className = &#39;year-row&#39;;&#xA;        tr.innerHTML = `&lt;td&gt;${yr}&lt;/td&gt;&lt;td&gt;${fmt(d.payment)}&lt;/td&gt;&lt;td&gt;${fmt(d.principal)}&lt;/td&gt;&lt;td&gt;${fmt(d.interest)}&lt;/td&gt;&lt;td&gt;${fmt(d.balance)}&lt;/td&gt;`;&#xA;        tbody.appendChild(tr);&#xA;      });&#xA;    } else {&#xA;      _schedule.forEach(r =&gt; {&#xA;        const tr = document.createElement(&#39;tr&#39;);&#xA;        tr.innerHTML = `&lt;td&gt;${r.mName} ${r.year}&lt;/td&gt;&lt;td&gt;${fmt(r.payment)}&lt;/td&gt;&lt;td&gt;${fmt(r.principal)}&lt;/td&gt;&lt;td&gt;${fmt(r.interest)}&lt;/td&gt;&lt;td&gt;${fmt(r.balance)}&lt;/td&gt;`;&#xA;        tbody.appendChild(tr);&#xA;      });&#xA;    }&#xA;  }&#xA;&#xA;  calcAmort();&#xA;})();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;div class=&#34;seo-content&#34;&gt;&#xA;&lt;h2 id=&#34;what-is-an-amortization-schedule&#34;&gt;What Is an Amortization Schedule?&lt;/h2&gt;&#xA;&lt;p&gt;An amortization schedule is a complete table of mortgage payments that shows how each payment is split between &lt;strong&gt;principal&lt;/strong&gt; (reducing your loan balance) and &lt;strong&gt;interest&lt;/strong&gt; (the lender&amp;rsquo;s fee for the loan).&lt;/p&gt;</description>
    </item>
    <item>
      <title>Home Affordability Calculator</title>
      <link>http://localhost:1313/affordability-calculator/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/affordability-calculator/</guid>
      <description>&lt;div class=&#34;calc-card&#34;&gt;&#xA;  &lt;div class=&#34;calc-grid&#34;&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;af-income&#34;&gt;Annual Household Income&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;af-income&#34; value=&#34;100000&#34; min=&#34;10000&#34; step=&#34;1000&#34;&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;af-debts&#34;&gt;Monthly Debt Payments&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;af-debts&#34; value=&#34;500&#34; min=&#34;0&#34; step=&#34;50&#34;&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;span class=&#34;hint&#34;&gt;Car, student loans, credit cards, etc.&lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;af-down&#34;&gt;Down Payment&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;af-down&#34; value=&#34;60000&#34; min=&#34;0&#34; step=&#34;1000&#34;&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;af-rate&#34;&gt;Interest Rate&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-suffix&#34;&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;af-rate&#34; value=&#34;7.00&#34; min=&#34;0.1&#34; max=&#34;30&#34; step=&#34;0.05&#34;&gt;&#xA;        &lt;span class=&#34;suffix&#34;&gt;%&lt;/span&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;af-term&#34;&gt;Loan Term&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap&#34;&gt;&#xA;        &lt;select id=&#34;af-term&#34;&gt;&#xA;          &lt;option value=&#34;30&#34;&gt;30 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;20&#34;&gt;20 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;15&#34;&gt;15 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;10&#34;&gt;10 Years&lt;/option&gt;&#xA;        &lt;/select&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;af-tax&#34;&gt;Annual Property Tax Rate&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-suffix&#34;&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;af-tax&#34; value=&#34;1.20&#34; min=&#34;0&#34; max=&#34;5&#34; step=&#34;0.05&#34;&gt;&#xA;        &lt;span class=&#34;suffix&#34;&gt;%&lt;/span&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;span class=&#34;hint&#34;&gt;Avg. ~1.1% nationally&lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;btn-row&#34;&gt;&#xA;      &lt;button class=&#34;btn btn-primary&#34; onclick=&#34;calcAffordability()&#34;&gt;Calculate Affordability&lt;/button&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&#xA;  &lt;div class=&#34;results&#34; id=&#34;af-results&#34;&gt;&#xA;    &lt;div class=&#34;result-highlight&#34;&gt;&#xA;      &lt;div&gt;&#xA;        &lt;div class=&#34;big-number&#34; id=&#34;af-max-price&#34;&gt;$0&lt;/div&gt;&#xA;        &lt;div class=&#34;big-label&#34;&gt;Maximum Home Price&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div&gt;&#xA;        &lt;div class=&#34;big-number&#34; id=&#34;af-monthly&#34; style=&#34;font-size:1.5rem;color:#374151&#34;&gt;&lt;/div&gt;&#xA;        &lt;div class=&#34;big-label&#34; style=&#34;color:#6b7280&#34;&gt;Est. Monthly Payment&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;result-grid&#34;&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;af-max-loan&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Max Loan Amount&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;af-front-end&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Housing-to-Income Ratio&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;af-back-end&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Total Debt-to-Income Ratio&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item good&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;af-budget-label&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Budget Status&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;seo-content&#34; style=&#34;margin-top:1rem;&#34;&gt;&#xA;      &lt;p id=&#34;af-explanation&#34;&gt;&lt;/p&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script&gt;&#xA;(function(){&#xA;  window.calcAffordability = function() {&#xA;    const income  = parseFloat(document.getElementById(&#39;af-income&#39;).value) || 0;&#xA;    const debts   = parseFloat(document.getElementById(&#39;af-debts&#39;).value)  || 0;&#xA;    const down    = parseFloat(document.getElementById(&#39;af-down&#39;).value)   || 0;&#xA;    const rate    = parseFloat(document.getElementById(&#39;af-rate&#39;).value)   || 0;&#xA;    const term    = parseInt(document.getElementById(&#39;af-term&#39;).value)     || 30;&#xA;    const taxRate = parseFloat(document.getElementById(&#39;af-tax&#39;).value)    || 0;&#xA;&#xA;    if (income &lt;= 0 || rate &lt;= 0) return;&#xA;&#xA;    const monthlyIncome = income / 12;&#xA;    const mr = rate / 100 / 12;&#xA;    const n  = term * 12;&#xA;&#xA;    &#xA;    const maxHousing = monthlyIncome * 0.28;&#xA;    &#xA;    const maxTotal   = monthlyIncome * 0.36;&#xA;    const maxHousingBackEnd = maxTotal - debts;&#xA;    const maxMonthlyHousing = Math.min(maxHousing, maxHousingBackEnd);&#xA;&#xA;    &#xA;    &#xA;    &#xA;    function pitiForPrice(homePrice) {&#xA;      const loan = homePrice - down;&#xA;      if (loan &lt;= 0) return 0;&#xA;      const pi = loan * (mr * Math.pow(1+mr,n)) / (Math.pow(1+mr,n)-1);&#xA;      const monthlyTax = homePrice * (taxRate / 100) / 12;&#xA;      return pi + monthlyTax;&#xA;    }&#xA;&#xA;    &#xA;    let lo = down, hi = income * 20;&#xA;    for (let i = 0; i &lt; 50; i++) {&#xA;      const mid = (lo + hi) / 2;&#xA;      if (pitiForPrice(mid) &lt;= maxMonthlyHousing) lo = mid; else hi = mid;&#xA;    }&#xA;    const maxHomePrice = lo;&#xA;    const maxLoan = Math.max(maxHomePrice - down, 0);&#xA;    const monthlyPayment = pitiForPrice(maxHomePrice);&#xA;    const frontEnd = (monthlyPayment / monthlyIncome * 100).toFixed(1);&#xA;    const backEnd  = ((monthlyPayment + debts) / monthlyIncome * 100).toFixed(1);&#xA;&#xA;    const fmt = v =&gt; &#39;$&#39; + v.toLocaleString(&#39;en-US&#39;, {minimumFractionDigits:0, maximumFractionDigits:0});&#xA;    document.getElementById(&#39;af-max-price&#39;).textContent  = fmt(maxHomePrice);&#xA;    document.getElementById(&#39;af-monthly&#39;).textContent    = fmt(monthlyPayment) + &#39;/mo&#39;;&#xA;    document.getElementById(&#39;af-max-loan&#39;).textContent   = fmt(maxLoan);&#xA;    document.getElementById(&#39;af-front-end&#39;).textContent  = frontEnd + &#39;%&#39;;&#xA;    document.getElementById(&#39;af-back-end&#39;).textContent   = backEnd + &#39;%&#39;;&#xA;&#xA;    const backEndNum = parseFloat(backEnd);&#xA;    let status, explanation;&#xA;    if (backEndNum &lt;= 28) {&#xA;      status = &#39;✅ Conservative&#39;; explanation = `Your debt-to-income ratio of ${backEnd}% is well below the 36% guideline, giving you a comfortable cushion for unexpected expenses.`;&#xA;    } else if (backEndNum &lt;= 36) {&#xA;      status = &#39;✅ Good&#39;; explanation = `Your total DTI of ${backEnd}% falls within standard lending guidelines. Most lenders will approve loans at this level.`;&#xA;    } else if (backEndNum &lt;= 43) {&#xA;      status = &#39;⚠️ Stretched&#39;; explanation = `At ${backEnd}% DTI, you may qualify but you&#39;ll have less budget flexibility. Consider paying down debts or saving a larger down payment.`;&#xA;    } else {&#xA;      status = &#39;❌ High DTI&#39;; explanation = `A DTI of ${backEnd}% exceeds conventional guidelines. Reduce monthly debts or increase income before applying.`;&#xA;    }&#xA;&#xA;    document.getElementById(&#39;af-budget-label&#39;).textContent = status;&#xA;    document.getElementById(&#39;af-explanation&#39;).textContent = explanation;&#xA;    document.getElementById(&#39;af-results&#39;).classList.add(&#39;visible&#39;);&#xA;  };&#xA;&#xA;  calcAffordability();&#xA;})();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;div class=&#34;seo-content&#34;&gt;&#xA;&lt;h2 id=&#34;how-much-house-can-i-afford&#34;&gt;How Much House Can I Afford?&lt;/h2&gt;&#xA;&lt;p&gt;This calculator uses the standard &lt;strong&gt;28/36 rule&lt;/strong&gt; used by most mortgage lenders to determine how much home you can afford.&lt;/p&gt;</description>
    </item>
    <item>
      <title>Mortgage Calculator</title>
      <link>http://localhost:1313/mortgage-calculator/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/mortgage-calculator/</guid>
      <description>&lt;div class=&#34;calc-card&#34;&gt;&#xA;  &lt;div class=&#34;calc-grid&#34;&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;mc-price&#34;&gt;Home Price&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;mc-price&#34; value=&#34;400000&#34; min=&#34;10000&#34; step=&#34;1000&#34;&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;mc-down&#34;&gt;Down Payment&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-suffix&#34;&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;mc-down&#34; value=&#34;80000&#34; min=&#34;0&#34; step=&#34;1000&#34;&gt;&#xA;        &lt;span class=&#34;suffix&#34; id=&#34;mc-down-pct&#34;&gt;20%&lt;/span&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;mc-rate&#34;&gt;Annual Interest Rate&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-suffix&#34;&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;mc-rate&#34; value=&#34;7.00&#34; min=&#34;0.1&#34; max=&#34;30&#34; step=&#34;0.05&#34;&gt;&#xA;        &lt;span class=&#34;suffix&#34;&gt;%&lt;/span&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;mc-term&#34;&gt;Loan Term&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap&#34;&gt;&#xA;        &lt;select id=&#34;mc-term&#34;&gt;&#xA;          &lt;option value=&#34;30&#34;&gt;30 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;20&#34;&gt;20 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;15&#34;&gt;15 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;10&#34;&gt;10 Years&lt;/option&gt;&#xA;        &lt;/select&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;mc-tax&#34;&gt;Annual Property Tax&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;mc-tax&#34; value=&#34;4800&#34; min=&#34;0&#34; step=&#34;100&#34;&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;span class=&#34;hint&#34;&gt;Optional — for PITI estimate&lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;mc-ins&#34;&gt;Annual Home Insurance&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;mc-ins&#34; value=&#34;1200&#34; min=&#34;0&#34; step=&#34;100&#34;&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;span class=&#34;hint&#34;&gt;Optional — for PITI estimate&lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;btn-row&#34;&gt;&#xA;      &lt;button class=&#34;btn btn-primary&#34; onclick=&#34;calcMortgage()&#34;&gt;Calculate Payment&lt;/button&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&#xA;  &#xA;  &lt;div class=&#34;results&#34; id=&#34;mc-results&#34;&gt;&#xA;    &lt;div class=&#34;result-highlight&#34;&gt;&#xA;      &lt;div&gt;&#xA;        &lt;div class=&#34;big-number&#34; id=&#34;mc-piti&#34;&gt;$0&lt;/div&gt;&#xA;        &lt;div class=&#34;big-label&#34;&gt;Estimated Monthly Payment (PITI)&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div&gt;&#xA;        &lt;div class=&#34;big-number&#34; id=&#34;mc-pi&#34; style=&#34;font-size:1.5rem;color:#374151&#34;&gt;&lt;/div&gt;&#xA;        &lt;div class=&#34;big-label&#34; style=&#34;color:#6b7280&#34;&gt;Principal &amp; Interest only&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;result-grid&#34;&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;mc-loan-amt&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Loan Amount&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;mc-total-int&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Total Interest&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;mc-total-paid&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Total Paid&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;mc-payoff&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Payoff Date&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &#xA;    &lt;div class=&#34;piti-chart&#34;&gt;&#xA;      &lt;svg id=&#34;mc-pie&#34; width=&#34;140&#34; height=&#34;140&#34; viewBox=&#34;0 0 140 140&#34;&gt;&lt;/svg&gt;&#xA;      &lt;div class=&#34;piti-legend&#34; id=&#34;mc-legend&#34;&gt;&lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script&gt;&#xA;(function() {&#xA;  &#xA;  const priceEl = document.getElementById(&#39;mc-price&#39;);&#xA;  const downEl  = document.getElementById(&#39;mc-down&#39;);&#xA;  const pctLbl  = document.getElementById(&#39;mc-down-pct&#39;);&#xA;&#xA;  function updatePct() {&#xA;    const p = parseFloat(priceEl.value) || 0;&#xA;    const d = parseFloat(downEl.value)  || 0;&#xA;    pctLbl.textContent = p &gt; 0 ? (d / p * 100).toFixed(1) + &#39;%&#39; : &#39;0%&#39;;&#xA;  }&#xA;  priceEl.addEventListener(&#39;input&#39;, updatePct);&#xA;  downEl.addEventListener(&#39;input&#39;, updatePct);&#xA;  updatePct();&#xA;&#xA;  window.calcMortgage = function() {&#xA;    const price = parseFloat(priceEl.value)  || 0;&#xA;    const down  = parseFloat(downEl.value)   || 0;&#xA;    const rate  = parseFloat(document.getElementById(&#39;mc-rate&#39;).value) || 0;&#xA;    const term  = parseInt(document.getElementById(&#39;mc-term&#39;).value)   || 30;&#xA;    const tax   = parseFloat(document.getElementById(&#39;mc-tax&#39;).value)  || 0;&#xA;    const ins   = parseFloat(document.getElementById(&#39;mc-ins&#39;).value)  || 0;&#xA;&#xA;    const loan = price - down;&#xA;    if (loan &lt;= 0 || rate &lt;= 0) return;&#xA;&#xA;    const monthlyRate = rate / 100 / 12;&#xA;    const n = term * 12;&#xA;    const pi = loan * (monthlyRate * Math.pow(1 + monthlyRate, n)) / (Math.pow(1 + monthlyRate, n) - 1);&#xA;    const monthlyTax = tax / 12;&#xA;    const monthlyIns = ins / 12;&#xA;    const piti = pi + monthlyTax + monthlyIns;&#xA;    const totalInterest = pi * n - loan;&#xA;    const totalPaid = piti * n;&#xA;&#xA;    const payoffDate = new Date();&#xA;    payoffDate.setMonth(payoffDate.getMonth() + n);&#xA;    const payoffStr = payoffDate.toLocaleDateString(&#39;en-US&#39;, { month: &#39;short&#39;, year: &#39;numeric&#39; });&#xA;&#xA;    document.getElementById(&#39;mc-piti&#39;).textContent    = fmt(piti);&#xA;    document.getElementById(&#39;mc-pi&#39;).textContent      = fmt(pi) + &#39; P&amp;I&#39;;&#xA;    document.getElementById(&#39;mc-loan-amt&#39;).textContent = fmt(loan);&#xA;    document.getElementById(&#39;mc-total-int&#39;).textContent = fmt(totalInterest);&#xA;    document.getElementById(&#39;mc-total-paid&#39;).textContent = fmt(totalPaid);&#xA;    document.getElementById(&#39;mc-payoff&#39;).textContent  = payoffStr;&#xA;&#xA;    &#xA;    drawPie([&#xA;      { label: &#39;Principal &amp; Interest&#39;, value: pi,          color: &#39;#1a56db&#39; },&#xA;      { label: &#39;Property Tax&#39;,         value: monthlyTax,  color: &#39;#f59e0b&#39; },&#xA;      { label: &#39;Home Insurance&#39;,       value: monthlyIns,  color: &#39;#10b981&#39; },&#xA;    ]);&#xA;&#xA;    document.getElementById(&#39;mc-results&#39;).classList.add(&#39;visible&#39;);&#xA;  };&#xA;&#xA;  function fmt(n) {&#xA;    return &#39;$&#39; + n.toLocaleString(&#39;en-US&#39;, { minimumFractionDigits: 0, maximumFractionDigits: 0 });&#xA;  }&#xA;&#xA;  function drawPie(slices) {&#xA;    const svg = document.getElementById(&#39;mc-pie&#39;);&#xA;    const legend = document.getElementById(&#39;mc-legend&#39;);&#xA;    svg.innerHTML = &#39;&#39;;&#xA;    legend.innerHTML = &#39;&#39;;&#xA;    const total = slices.reduce((s, sl) =&gt; s + sl.value, 0);&#xA;    if (total &lt;= 0) return;&#xA;&#xA;    const cx = 70, cy = 70, r = 65;&#xA;    let startAngle = -Math.PI / 2;&#xA;&#xA;    slices.forEach(sl =&gt; {&#xA;      if (sl.value &lt;= 0) return;&#xA;      const angle = (sl.value / total) * 2 * Math.PI;&#xA;      const endAngle = startAngle + angle;&#xA;      const x1 = cx + r * Math.cos(startAngle);&#xA;      const y1 = cy + r * Math.sin(startAngle);&#xA;      const x2 = cx + r * Math.cos(endAngle);&#xA;      const y2 = cy + r * Math.sin(endAngle);&#xA;      const large = angle &gt; Math.PI ? 1 : 0;&#xA;      const path = document.createElementNS(&#39;http://www.w3.org/2000/svg&#39;, &#39;path&#39;);&#xA;      path.setAttribute(&#39;d&#39;, `M${cx},${cy} L${x1},${y1} A${r},${r} 0 ${large},1 ${x2},${y2} Z`);&#xA;      path.setAttribute(&#39;fill&#39;, sl.color);&#xA;      svg.appendChild(path);&#xA;      startAngle = endAngle;&#xA;&#xA;      const dot = document.createElement(&#39;div&#39;);&#xA;      dot.className = &#39;legend-item&#39;;&#xA;      dot.innerHTML = `&lt;span class=&#34;legend-dot&#34; style=&#34;background:${sl.color}&#34;&gt;&lt;/span&gt;&lt;span&gt;${sl.label}: &lt;strong&gt;${fmt(sl.value)}&lt;/strong&gt;&lt;/span&gt;`;&#xA;      legend.appendChild(dot);&#xA;    });&#xA;  }&#xA;&#xA;  &#xA;  calcMortgage();&#xA;})();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;div class=&#34;seo-content&#34;&gt;&#xA;&lt;h2 id=&#34;how-to-use-this-mortgage-calculator&#34;&gt;How to Use This Mortgage Calculator&lt;/h2&gt;&#xA;&lt;p&gt;Enter your &lt;strong&gt;home price&lt;/strong&gt; and &lt;strong&gt;down payment&lt;/strong&gt; to calculate your loan amount. Then set your &lt;strong&gt;interest rate&lt;/strong&gt; and &lt;strong&gt;loan term&lt;/strong&gt;, and optionally add your estimated property taxes and insurance to see your full monthly payment (PITI).&lt;/p&gt;</description>
    </item>
    <item>
      <title>Refinance Calculator</title>
      <link>http://localhost:1313/refinance-calculator/</link>
      <pubDate>Mon, 01 Jan 0001 00:00:00 +0000</pubDate>
      <guid>http://localhost:1313/refinance-calculator/</guid>
      <description>&lt;div class=&#34;calc-card&#34;&gt;&#xA;  &lt;div class=&#34;calc-grid&#34;&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;rf-balance&#34;&gt;Current Loan Balance&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;rf-balance&#34; value=&#34;280000&#34; min=&#34;1000&#34; step=&#34;1000&#34;&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;rf-cur-rate&#34;&gt;Current Interest Rate&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-suffix&#34;&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;rf-cur-rate&#34; value=&#34;7.50&#34; min=&#34;0.1&#34; max=&#34;30&#34; step=&#34;0.05&#34;&gt;&#xA;        &lt;span class=&#34;suffix&#34;&gt;%&lt;/span&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;rf-cur-term&#34;&gt;Remaining Term&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap&#34;&gt;&#xA;        &lt;select id=&#34;rf-cur-term&#34;&gt;&#xA;          &lt;option value=&#34;30&#34;&gt;30 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;29&#34;&gt;29 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;28&#34;&gt;28 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;27&#34;&gt;27 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;25&#34;&gt;25 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;20&#34;&gt;20 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;15&#34;&gt;15 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;10&#34;&gt;10 Years&lt;/option&gt;&#xA;        &lt;/select&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;rf-new-rate&#34;&gt;New Interest Rate&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-suffix&#34;&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;rf-new-rate&#34; value=&#34;6.50&#34; min=&#34;0.1&#34; max=&#34;30&#34; step=&#34;0.05&#34;&gt;&#xA;        &lt;span class=&#34;suffix&#34;&gt;%&lt;/span&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;rf-new-term&#34;&gt;New Loan Term&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap&#34;&gt;&#xA;        &lt;select id=&#34;rf-new-term&#34;&gt;&#xA;          &lt;option value=&#34;30&#34;&gt;30 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;20&#34;&gt;20 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;15&#34;&gt;15 Years&lt;/option&gt;&#xA;          &lt;option value=&#34;10&#34;&gt;10 Years&lt;/option&gt;&#xA;        &lt;/select&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;field&#34;&gt;&#xA;      &lt;label for=&#34;rf-closing&#34;&gt;Closing Costs&lt;/label&gt;&#xA;      &lt;div class=&#34;input-wrap has-prefix&#34;&gt;&#xA;        &lt;span class=&#34;prefix&#34;&gt;$&lt;/span&gt;&#xA;        &lt;input type=&#34;number&#34; id=&#34;rf-closing&#34; value=&#34;4500&#34; min=&#34;0&#34; step=&#34;100&#34;&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;span class=&#34;hint&#34;&gt;Typically 2–5% of loan amount&lt;/span&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;btn-row&#34;&gt;&#xA;      &lt;button class=&#34;btn btn-primary&#34; onclick=&#34;calcRefinance()&#34;&gt;Calculate Savings&lt;/button&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&#xA;  &lt;div class=&#34;results&#34; id=&#34;rf-results&#34;&gt;&#xA;    &lt;div class=&#34;result-highlight&#34;&gt;&#xA;      &lt;div&gt;&#xA;        &lt;div class=&#34;big-number&#34; id=&#34;rf-monthly-savings&#34;&gt;$0&lt;/div&gt;&#xA;        &lt;div class=&#34;big-label&#34;&gt;Monthly Savings&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div&gt;&#xA;        &lt;div class=&#34;big-number&#34; id=&#34;rf-breakeven&#34; style=&#34;font-size:1.5rem;color:#374151&#34;&gt;&lt;/div&gt;&#xA;        &lt;div class=&#34;big-label&#34; style=&#34;color:#6b7280&#34;&gt;Break-Even Point&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;&#xA;    &lt;div class=&#34;result-grid&#34;&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;rf-cur-payment&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Current Payment&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item good&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;rf-new-payment&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;New Payment&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;rf-cur-interest&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Remaining Interest (Current)&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item good&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;rf-new-interest&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Total Interest (New)&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item good&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;rf-lifetime-savings&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Lifetime Interest Savings&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;      &lt;div class=&#34;result-item&#34;&gt;&#xA;        &lt;div class=&#34;val&#34; id=&#34;rf-verdict&#34;&gt;—&lt;/div&gt;&#xA;        &lt;div class=&#34;lbl&#34;&gt;Should You Refinance?&lt;/div&gt;&#xA;      &lt;/div&gt;&#xA;    &lt;/div&gt;&#xA;  &lt;/div&gt;&#xA;&lt;/div&gt;&#xA;&#xA;&lt;script&gt;&#xA;(function(){&#xA;  function calcPayment(loan, annualRate, termYears) {&#xA;    const mr = annualRate / 100 / 12;&#xA;    const n  = termYears * 12;&#xA;    if (mr === 0) return loan / n;&#xA;    return loan * (mr * Math.pow(1+mr,n)) / (Math.pow(1+mr,n)-1);&#xA;  }&#xA;&#xA;  function totalInterest(loan, annualRate, termYears) {&#xA;    return calcPayment(loan, annualRate, termYears) * termYears * 12 - loan;&#xA;  }&#xA;&#xA;  window.calcRefinance = function() {&#xA;    const balance  = parseFloat(document.getElementById(&#39;rf-balance&#39;).value)   || 0;&#xA;    const curRate  = parseFloat(document.getElementById(&#39;rf-cur-rate&#39;).value)  || 0;&#xA;    const curTerm  = parseInt(document.getElementById(&#39;rf-cur-term&#39;).value)    || 30;&#xA;    const newRate  = parseFloat(document.getElementById(&#39;rf-new-rate&#39;).value)  || 0;&#xA;    const newTerm  = parseInt(document.getElementById(&#39;rf-new-term&#39;).value)    || 30;&#xA;    const closing  = parseFloat(document.getElementById(&#39;rf-closing&#39;).value)   || 0;&#xA;&#xA;    if (balance &lt;= 0 || curRate &lt;= 0 || newRate &lt;= 0) return;&#xA;&#xA;    const curPayment = calcPayment(balance, curRate, curTerm);&#xA;    const newPayment = calcPayment(balance, newRate, newTerm);&#xA;    const monthlySavings = curPayment - newPayment;&#xA;    const curInterestRemaining = totalInterest(balance, curRate, curTerm);&#xA;    const newInterestTotal = totalInterest(balance, newRate, newTerm);&#xA;    const lifetimeSavings = curInterestRemaining - newInterestTotal - closing;&#xA;&#xA;    const fmt = v =&gt; &#39;$&#39; + Math.abs(v).toLocaleString(&#39;en-US&#39;, {minimumFractionDigits:0, maximumFractionDigits:0});&#xA;&#xA;    document.getElementById(&#39;rf-cur-payment&#39;).textContent  = fmt(curPayment);&#xA;    document.getElementById(&#39;rf-new-payment&#39;).textContent  = fmt(newPayment);&#xA;    document.getElementById(&#39;rf-cur-interest&#39;).textContent = fmt(curInterestRemaining);&#xA;    document.getElementById(&#39;rf-new-interest&#39;).textContent = fmt(newInterestTotal);&#xA;&#xA;    if (monthlySavings &gt; 0) {&#xA;      const breakEvenMonths = closing &gt; 0 ? Math.ceil(closing / monthlySavings) : 0;&#xA;      const breakEvenStr = breakEvenMonths === 0 ? &#39;No break-even needed&#39; :&#xA;        breakEvenMonths &lt; 12 ? `${breakEvenMonths} months` :&#xA;        `${(breakEvenMonths/12).toFixed(1)} years`;&#xA;      document.getElementById(&#39;rf-monthly-savings&#39;).textContent = fmt(monthlySavings) + &#39;/mo&#39;;&#xA;      document.getElementById(&#39;rf-breakeven&#39;).textContent = breakEvenStr;&#xA;&#xA;      let verdict;&#xA;      if (breakEvenMonths === 0 || breakEvenMonths &lt;= 24) verdict = &#39;✅ Likely Worth It&#39;;&#xA;      else if (breakEvenMonths &lt;= 60) verdict = &#39;⚠️ Consider It&#39;;&#xA;      else verdict = &#39;❌ Think Carefully&#39;;&#xA;      document.getElementById(&#39;rf-verdict&#39;).textContent = verdict;&#xA;    } else {&#xA;      document.getElementById(&#39;rf-monthly-savings&#39;).textContent = &#39;-&#39; + fmt(Math.abs(monthlySavings)) + &#39;/mo&#39;;&#xA;      document.getElementById(&#39;rf-breakeven&#39;).textContent = &#39;N/A&#39;;&#xA;      document.getElementById(&#39;rf-verdict&#39;).textContent = &#39;❌ Not Recommended&#39;;&#xA;    }&#xA;&#xA;    const savingsSign = lifetimeSavings &gt;= 0 ? &#39;&#39; : &#39;-&#39;;&#xA;    document.getElementById(&#39;rf-lifetime-savings&#39;).textContent = savingsSign + fmt(lifetimeSavings);&#xA;&#xA;    document.getElementById(&#39;rf-results&#39;).classList.add(&#39;visible&#39;);&#xA;  };&#xA;&#xA;  calcRefinance();&#xA;})();&#xA;&lt;/script&gt;&#xA;&#xA;&lt;div class=&#34;seo-content&#34;&gt;&#xA;&lt;h2 id=&#34;should-you-refinance-your-mortgage&#34;&gt;Should You Refinance Your Mortgage?&lt;/h2&gt;&#xA;&lt;p&gt;Refinancing replaces your current mortgage with a new loan — ideally at a lower interest rate, shorter term, or both. This calculator helps you compare your current loan to a potential new one and see whether the numbers make sense.&lt;/p&gt;</description>
    </item>
